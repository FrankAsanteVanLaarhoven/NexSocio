{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "description": "NEXSOCIO - World-Leading SOTA Socio-Technical Platform",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure/cdk"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "sharp": "^0.35.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  }
}
